{
  // Runtime files for this persona. Keep each persona under its own runtime folder.
  "runtime": {
    // Base runtime folder for generated files.
    "data_dir": "profiles/wheatly/runtime",
    // JSONL conversation log.
    "turn_log": "profiles/wheatly/runtime/logs/turns.jsonl",
    // JSONL tool audit log with each request, result, source, and duration.
    "tool_log": "profiles/wheatly/runtime/logs/tools.jsonl",
    // Persistent machine state, for example eye expression and latency stats.
    "state_dir": "profiles/wheatly/runtime/state",
    // Default language hint for runtime components.
    "default_language": "en"
  },
  // Microphone recording and simple VAD.
  "audio": {
    // Input sample rate expected by STT.
    "sample_rate": 16000,
    // Mono input.
    "channels": 1,
    // RMS threshold for speech detection. Raise in noisy rooms, lower if it misses speech.
    "vad_threshold": 0.018,
    // Minimum speech duration before accepting an utterance.
    "min_speech_seconds": 0.45,
    // Silence duration that ends the utterance; increase if you pause while thinking.
    "silence_seconds": 7.0,
    // Keep only this much trailing silence in the WAV sent to STT.
    "trailing_silence_keep_seconds": 0.6,
    // Hard cap for one user utterance even if VAD keeps hearing speech.
    "max_utterance_seconds": 45.0,
    // Maximum time to wait for speech before timing out.
    "max_wait_seconds": 30.0,
    // Recorded input audio folder.
    "utterance_dir": "profiles/wheatly/runtime/audio",
    // Show experimental live transcript while the microphone is still recording.
    "partial_transcript_enabled": true,
    // How often to run preview STT on the current audio snapshot. Raise on weaker hardware.
    "partial_transcript_interval_seconds": 1.1,
    // Minimum captured speech before the first preview STT run.
    "partial_transcript_min_audio_seconds": 0.2,
    // Use the last live preview transcript as the final user text when it is fresh enough.
    "partial_transcript_use_as_final": true,
    // Maximum age of the last preview transcript at recording end before falling back to full STT.
    "partial_transcript_final_max_age_seconds": 8.0,
    // Play short non-TTS chimes on listening start and stop.
    "listening_chimes_enabled": true,
    // Gain for generated listening chimes. Keep under 0.4 to avoid startling peaks.
    "listening_chime_volume": 0.28,
    // While TTS is speaking, listen for a loud stop word to interrupt playback.
    "speech_interrupt_enabled": true,
    // Voice command that stops current speech output.
    "speech_interrupt_phrase": "stop",
    // Absolute RMS floor for interrupt candidates. This is intentionally above normal VAD.
    "speech_interrupt_min_rms": 0.055,
    // Candidate must also exceed normal VAD by this factor.
    "speech_interrupt_vad_multiplier": 3.0,
    // Candidate must be louder than the current speaker bleed by this factor.
    "speech_interrupt_baseline_multiplier": 2.4,
    // Ignore the initial playback onset and learn speaker bleed before accepting interrupts.
    "speech_interrupt_grace_seconds": 0.6,
    // Audio kept before the loud trigger so the beginning of "stop" is not clipped.
    "speech_interrupt_pre_roll_seconds": 0.35,
    // Short verification clip length sent through STT after the trigger.
    "speech_interrupt_record_seconds": 0.9,
    // Ignore long transcripts so normal assistant speech containing "stop" is less likely to match.
    "speech_interrupt_max_words": 4,
    // If true, pause TTS while verifying stop-interrupt candidates.
    // Keep false for smoother playback; verification runs in background.
    "speech_interrupt_pause_tts_while_verifying": false
  },
  // Persona identity exposed to prompts.
  "agent": {
    // Assistant display/name in prompts.
    "name": "Wheatly",
    // Compact personality description used by system.md.
    "persona": "compact, fast, slightly nervous, helpful robot",
    // Default answer language.
    "default_response_language": "English"
  },
  // Speech-to-text backend.
  "stt": {
    // Options: keyboard, faster_whisper, whisper_cpp, remote_fallback.
    // remote_fallback tries Janka Mac first, then loads the local fallback model below.
    "backend": "remote_fallback",
    // Local fallback model name/path. Language mode overrides this per language.
    "model": "small.en",
    // Force English recognition for now.
    "language": "en",
    // Use CPU for portability.
    "device": "cpu",
    // int8 is the practical CPU baseline.
    "compute_type": "int8",
    // whisper.cpp executable if backend is whisper_cpp.
    "whisper_cpp_binary": "whisper-cli",
    // whisper.cpp model path if backend is whisper_cpp.
    "whisper_cpp_model": "models/whisper/ggml-small.en.bin",
    // Extra whisper.cpp arguments.
    "whisper_cpp_args": [
      "--no-timestamps"
    ],
    // OpenAI-compatible remote STT endpoint on Janka Mac.
    "remote_base_url": "http://jankas-mac-mini.local:8765/v1",
    // API key is optional for the LAN server.
    "remote_api_key": "EMPTY",
    // Remote model requested for the active language. Language mode overrides this.
    "remote_model": "small.en",
    // Keep probes/failures short so the robot falls back quickly.
    "remote_probe_timeout_seconds": 0.4,
    "remote_request_timeout_seconds": 20.0,
    // Local fallback backend used when the remote STT server is unreachable.
    "remote_fallback_backend": "faster_whisper"
  },
  // Explicit language mode. Switch by saying configured phrases or via set_language tool.
  "language": {
    // If true, active language controls STT hint/model, LLM prompt hint, and TTS voice.
    "enabled": true,
    // Startup language when no persisted state exists.
    "default": "en",
    // Save last selected language under profiles/wheatly/runtime/state.
    "persist": true,
    // File name inside runtime.state_dir.
    "state_file": "language.json",
    // Per-language runtime overrides.
    "languages": {
      // English fast mode.
      "en": {
        // Human-readable language name.
        "label": "English",
        // Language instruction injected into the LLM prompt.
        "response_language": "English",
        // Show live partial transcript while listening in English.
        "audio_partial_transcript_enabled": true,
        // English small STT is fast enough that a fresh partial transcript can be used as final text.
        "audio_partial_transcript_use_as_final": true,
        // faster-whisper model for this language.
        "stt_model": "small.en",
        // STT language hint.
        "stt_language": "en",
        // Remote STT model to request from Janka Mac. Same quality class as local English.
        "remote_stt_model": "small.en",
        // TTS backend for English. Keep Piper local/offline here.
        "tts_backend": "piper",
        // macOS say voice label if that backend is used.
        "tts_voice": "Daniel",
        // Piper voice model for this language.
        "tts_piper_model": "models/piper/en_GB-alan-medium.onnx",
        // Optional Piper config path.
        "tts_piper_config": null,
        // Optional Piper speaker id.
        "tts_piper_speaker": null,
        // Edge TTS voice if this language uses backend edge_tts.
        "tts_edge_voice": "en-GB-RyanNeural",
        // Edge TTS rate. Examples: "-5%", "+10%".
        "tts_edge_rate": "+0%",
        // Edge TTS pitch. Examples: "+8Hz", "-4Hz".
        "tts_edge_pitch": "+0Hz",
        // Edge TTS gain. Examples: "+0%", "+10%".
        "tts_edge_volume": "+0%",
        // Piper speed. Lower is faster.
        "tts_length_scale": 0.8,
        // Piper voice variation.
        "tts_noise_scale": 0.72,
        // Piper prosody variation.
        "tts_noise_w_scale": 0.82,
        // Silence inserted after sentences.
        "tts_sentence_silence": 0.0,
        // Playback gain multiplier.
        "tts_volume": 1.05,
        // Silence prepended before playback to avoid clipped first letters.
        "tts_leading_silence_ms": 0,
        // If true, speech starts while text is still streaming.
        "tts_stream_speech": true,
        // English first streamed TTS chunk target. Keep low so speech starts quickly.
        "tts_stream_initial_min_words": 8,
        // English later streamed TTS chunk target. Moderate chunks reduce gaps without waiting too long.
        "tts_stream_min_words": 22,
        // English hard cap for streamed TTS chunks.
        "tts_stream_max_words": 70,
        // English minimum timeout fallback chunk size.
        "tts_stream_feedback_min_words": 14,
        // English maximum wait before first speech feedback.
        "tts_stream_max_initial_wait_seconds": 0.7,
        // English maximum wait between streamed chunks before forcing a smaller feedback chunk.
        "tts_stream_max_inter_chunk_wait_seconds": 1.6,
        // English startup prebuffer for pipelined synth+playback.
        "tts_stream_playback_prebuffer_chunks": 4,
        // Maximum extra wait to collect prebuffered chunks before first playback.
        "tts_stream_playback_prebuffer_max_wait_seconds": 0.8,
        // Spoken/written confirmation after switching.
        "confirmation": "Hi",
        // Printed/spoken when the smarter online model is selected while starting in English.
        "online_model_message": "using smarter online model",
        // Printed/spoken when the local offline model is selected while starting in English.
        "offline_model_message": "using offline model",
        // Online LM Studio model to use for English. Offline model remains llm.model.
        "online_llm_model": "lmstudio-community/gemma-4-31b-it",
        // Exact-ish phrases that trigger direct switching before the LLM.
        "switch_phrases": [
          "switch to english",
          "speak english",
          "talk in english",
          "use english",
          "prepni na anglictinu",
          "hovor po anglicky"
        ],
        // Generic command phrases spoken in English. If already in English, this toggles to the previous/next language.
        "switch_language_phrases": [
          "switch language",
          "change language",
          "switch the language"
        ]
      },
      // Slovak quality mode. Uses Slovak fine-tuned Whisper large-v3-turbo in CTranslate2 int8 format.
      "sk": {
        // Human-readable language name.
        "label": "Slovak",
        // Language instruction injected into the LLM prompt.
        "response_language": "Slovak",
        // Disabled for Slovak large STT; live partial transcription was slow and could repeat stale text.
        "audio_partial_transcript_enabled": false,
        // Always run one clean final Slovak transcription from the saved utterance.
        "audio_partial_transcript_use_as_final": false,
        // faster-whisper model for this language. This local folder is converted from NaiveNeuron/whisper-large-v3-turbo-sk.
        "stt_model": "models/whisper/whisper-large-v3-turbo-sk-ct2-int8",
        // STT language hint.
        "stt_language": "sk",
        // Remote STT model to request from Janka Mac. Full Slovak large-v3 is more accurate than the local turbo fallback.
        "remote_stt_model": "models/whisper/whisper-large-v3-sk-ct2-int8",
        // Slovak TTS backend. Current default is online Microsoft Edge neural voice for a male voice.
        "tts_backend": "edge_tts",
        // Human-readable/current voice label.
        "tts_voice": "sk-SK-LukasNeural",
        // Piper fallback voice model. To return to the old local female Slovak voice, set tts_backend to "piper".
        "tts_piper_model": "models/piper/sk_SK-lili-medium.onnx",
        // Optional Piper config path.
        "tts_piper_config": null,
        // Optional Piper speaker id.
        "tts_piper_speaker": null,
        // Edge TTS Slovak male voice.
        "tts_edge_voice": "sk-SK-LukasNeural",
        // Edge TTS speaking rate. Positive values speak faster.
        "tts_edge_rate": "+8%",
        // Edge TTS pitch. Lower value makes the Slovak male voice deeper.
        "tts_edge_pitch": "-14Hz",
        // Edge TTS gain.
        "tts_edge_volume": "+0%",
        // Piper speed. Slovak is slower for clearer pronunciation.
        "tts_length_scale": 0.84,
        // Piper voice variation. Slightly lower for a calmer, less sharp Slovak voice.
        "tts_noise_scale": 0.66,
        // Piper prosody variation.
        "tts_noise_w_scale": 0.78,
        // Silence inserted after sentences.
        "tts_sentence_silence": 0.04,
        // Playback gain multiplier.
        "tts_volume": 1.05,
        // Silence prepended before playback to avoid clipped first letters.
        "tts_leading_silence_ms": 80,
        // Stream Slovak speech too. Edge TTS may create small gaps, but starting early is more important.
        "tts_stream_speech": true,
        // Slovak first streamed TTS chunk target. Low enough for quick audible feedback.
        "tts_stream_initial_min_words": 3,
        // Slovak later streamed TTS chunk target. Larger than English to reduce Edge TTS network gaps.
        "tts_stream_min_words": 14,
        // Slovak hard cap for streamed TTS chunks.
        "tts_stream_max_words": 90,
        // Slovak minimum timeout fallback chunk size.
        "tts_stream_feedback_min_words": 6,
        // Slovak maximum wait before first speech feedback.
        "tts_stream_max_initial_wait_seconds": 0.35,
        // Slovak maximum wait between streamed chunks before forcing a smaller feedback chunk.
        "tts_stream_max_inter_chunk_wait_seconds": 0.7,
        // Slovak startup prebuffer for pipelined synth+playback.
        "tts_stream_playback_prebuffer_chunks": 2,
        // Maximum extra wait to collect prebuffered chunks before first playback.
        "tts_stream_playback_prebuffer_max_wait_seconds": 0.35,
        // Spoken/written confirmation after switching.
        "confirmation": "Ahoj",
        // Printed/spoken when the smarter online model is selected while starting in Slovak.
        "online_model_message": "Používam múdrejší online model.",
        // Printed/spoken when the local offline model is selected while starting in Slovak.
        "offline_model_message": "Používam offline model.",
        // Online LM Studio model to use for Slovak. Offline model remains llm.model.
        "online_llm_model": "lmstudio-community/gemma-4-31b-it",
        // Exact-ish phrases that trigger direct switching before the LLM.
        "switch_phrases": [
          "switch to slovak",
          "speak slovak",
          "talk in slovak",
          "use slovak",
          "hovor po slovensky",
          "prepni na slovencinu",
          "prejdi na slovencinu"
        ],
        // Generic command phrases spoken in Slovak. If already in Slovak, this toggles to the previous/next language.
        "switch_language_phrases": [
          "prepni jazyk",
          "zmen jazyk",
          "prehod jazyk"
        ]
      }
    }
  },
  // Local LLM runtime.
  "llm": {
    // Options: echo, ollama, openai_compat, llama_cpp, vllm, sglang.
    "backend": "ollama",
    // Ollama model tag.
    "model": "qwen3.5:4b",
    // Ollama API URL.
    "base_url": "http://localhost:11434",
    // API key for OpenAI-compatible backends; ignored by Ollama.
    "api_key": "EMPTY",
    // Sampling temperature.
    "temperature": 0.55,
    // Nucleus sampling cutoff.
    "top_p": 0.8,
    // Maximum generated tokens. Prompt still asks for short answers by default.
    "max_tokens": 2000,
    // HTTP request timeout.
    "timeout_seconds": 60.0,
    // Number of previous user/assistant turns to keep.
    "context_turns": 6,
    // Disable thinking mode for voice latency.
    "enable_thinking": false,
    // Strip <think>/reasoning output. Keep false when the model is configured not to think.
    "strip_reasoning": false,
    // Optional smarter OpenAI-compatible model checked at each new chat.
    "remote": {
      // If true, try this backend before using the local model.
      "enabled": true,
      // Remote backend type. LM Studio uses OpenAI-compatible API.
      "backend": "openai_compat",
      // LM Studio OpenAI API base URL. /v1 is accepted here.
      "base_url": "http://jankas-mac-mini.local:1234/v1",
      // Fallback model name if a language does not set online_llm_model. Empty string lets LM Studio use its current/default loaded model.
      "model": "",
      // API key for OpenAI-compatible servers. LM Studio usually ignores this.
      "api_key": "EMPTY",
      // Very fast startup probe timeout.
      "probe_timeout_seconds": 0.8,
      // Request timeout after the remote model has been selected.
      "request_timeout_seconds": 120.0,
      // Printed/spoken when the remote model is available.
      "online_message": "using smarter online model",
      // Printed/spoken when the remote model is not reachable.
      "offline_message": "using offline model"
    }
  },
  // Automatic conversation-derived memory. File paths are fixed under this profile:
  // auto_memory.md, memory_update.md, memory_consolidate.md, runtime/state/memory_state.json, and runtime/state/memory_candidates.jsonl.
  "memory": {
    // Keep manual memory.md and the remember tool unchanged; this controls only auto_memory.md.
    "auto_enabled": true,
    // Online memory updates can use assistant responses as context.
    "include_assistant_text_online": true,
    // Offline/local memory updates stay cheaper and use only user text.
    "include_assistant_text_offline": false,
    // Debug-friendly consolidation cadence. Increase after tuning.
    "full_rewrite_interval_days": 1.0,
    // Full consolidation is skipped unless the online model is selected.
    "full_rewrite_requires_online": true,
    // Raw turns from this many recent days are included in online consolidation.
    "full_rewrite_recent_days": 14,
    // Limit one incremental pass so startup cannot process an unbounded backlog.
    "max_turns_per_update": 12,
    // Limit compact candidate evidence passed to consolidation.
    "max_candidates_for_rewrite": 240,
    // Hard-ish prompt memory size target.
    "max_total_words": 700,
    // Section limits for generated auto_memory.md.
    "max_stable_facts": 12,
    "max_preferences": 10,
    "max_current_projects": 8,
    "max_recent_context": 8
  },
  // Text-to-speech and playback.
  "tts": {
    // Options: auto, none, macos_say, piper, external.
    "backend": "piper",
    // Enable speech output by default for this profile.
    "enabled": true,
    // Human-readable voice label.
    "voice": "Daniel",
    // Generated TTS audio folder.
    "output_dir": "profiles/wheatly/runtime/audio",
    // Play audio after synthesis.
    "playback": true,
    // Optional custom playback command. Null uses built-in playback.
    "playback_command": null,
    // Piper executable path.
    "piper_binary": ".venv/bin/piper",
    // Piper voice model path.
    "piper_model": "models/piper/en_GB-alan-medium.onnx",
    // Optional Piper config path. Null lets Piper infer it beside the model.
    "piper_config": null,
    // Optional Piper speaker id for multi-speaker models.
    "piper_speaker": null,
    // Edge TTS voice if backend is edge_tts.
    "edge_voice": "en-GB-RyanNeural",
    // Edge TTS speaking rate. Examples: "-5%", "+10%".
    "edge_rate": "+0%",
    // Edge TTS pitch adjustment. Examples: "+8Hz", "-4Hz".
    "edge_pitch": "+0Hz",
    // Edge TTS volume adjustment. Examples: "+0%", "+10%".
    "edge_volume": "+0%",
    // Lower is faster speech.
    "length_scale": 0.62,
    // Piper voice variation.
    "noise_scale": 0.72,
    // Piper prosody variation.
    "noise_w_scale": 0.82,
    // Silence inserted after sentences.
    "sentence_silence": 0.0,
    // Playback gain multiplier.
    "volume": 1.05,
    // Silence prepended before playback to avoid clipped first letters.
    "leading_silence_ms": 0,
    // Speak chunks before the full answer is complete.
    "stream_speech": true,
    // Adapt first spoken chunk from observed LLM/TTS speeds.
    "adaptive_streaming": true,
    // First spoken chunk target.
    "stream_initial_min_words": 3,
    // Later spoken chunk target.
    "stream_min_words": 14,
    // Hard cap for spoken chunks.
    "stream_max_words": 70,
    // Fallback first chunk size when startup wait expires.
    "stream_feedback_min_words": 6,
    // Maximum initial wait before some speech feedback starts.
    "stream_max_initial_wait_seconds": 0.25,
    // Maximum wait between streamed chunks before forcing a smaller feedback chunk.
    "stream_max_inter_chunk_wait_seconds": 0.55,
    // Number of prepared chunks to target before starting playback.
    "stream_playback_prebuffer_chunks": 2,
    // Maximum extra startup wait while collecting playback prebuffer.
    "stream_playback_prebuffer_max_wait_seconds": 0.35,
    // External TTS command for backend external. Use {text} and {output} placeholders.
    "external_command": null,
    // Optional ffmpeg post-filter.
    "filter": {
      // Disabled because filtered chunk playback caused static tails on macOS.
      "enabled": false,
      // ffmpeg executable.
      "ffmpeg_binary": "ffmpeg",
      // Filter preset name in src/wheatly/audio/filter.py.
      "preset": "wheatley_bright"
    }
  },
  // Local tool policy.
  "tools": {
    // Enable tool calling and deterministic pre-routing.
    "enabled": true,
    // Whitelisted shell commands by logical name. Keep empty unless you add safe tools.
    "allowed_commands": {},
    // Optional camera command. Leave null until a camera is configured.
    "photo_command": null,
    // Web search is explicit and provider-backed; it does not scrape search engine HTML.
    // Providers: brave, searxng, tavily. Brave uses BRAVE_SEARCH_API_KEY by default.
    "web_search_enabled": true,
    "web_search_provider": "brave",
    // Required only for searxng, for example "http://127.0.0.1:8888".
    "web_search_endpoint": "",
    "web_search_api_key_env": "BRAVE_SEARCH_API_KEY",
    "web_search_max_results": 5,
    "web_search_timeout_seconds": 5.0,
    // Fetch a known public URL and strip HTML into readable text/markdown-ish output.
    "web_fetch_enabled": true,
    "web_fetch_timeout_seconds": 8.0,
    "web_fetch_max_bytes": 1000000,
    "web_fetch_max_chars": 12000,
    // Keep false unless you deliberately want URL fetching to reach LAN/localhost services.
    "web_fetch_allow_private_networks": false,
    "web_fetch_user_agent": "Wheatly/0.1 local voice assistant"
  },
  // Editable profile files. Relative paths resolve inside this profile folder.
  "prompts": {
    // Main system behavior.
    "system_path": "system.md",
    // Always-on user preference instructions.
    "user_path": "user.md",
    // Tool descriptions and tool instructions.
    "tools_path": "tools.jsonc",
    // Persistent memory injected into each new turn.
    "memory_path": "memory.md"
  }
}
