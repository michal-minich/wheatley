{
  // Runtime files for this persona. Keep each persona under its own runtime folder.
  "runtime": {
    // Base runtime folder for generated files.
    "data_dir": "runtime/wheatly",
    // JSONL conversation log.
    "turn_log": "runtime/wheatly/logs/turns.jsonl",
    // Persistent machine state, for example eye expression and latency stats.
    "state_dir": "runtime/wheatly/state",
    // Default language hint for runtime components.
    "default_language": "en"
  },
  // Microphone recording and simple VAD.
  "audio": {
    // Input sample rate expected by STT.
    "sample_rate": 16000,
    // Mono input.
    "channels": 1,
    // RMS threshold for speech detection. Raise in noisy rooms, lower if it misses speech.
    "vad_threshold": 0.018,
    // Minimum speech duration before accepting an utterance.
    "min_speech_seconds": 0.45,
    // Silence duration that ends the utterance.
    "silence_seconds": 5,
    // Maximum single user utterance duration.
    "max_utterance_seconds": 12.0,
    // Maximum time to wait for speech before timing out.
    "max_wait_seconds": 30.0,
    // Recorded input audio folder.
    "utterance_dir": "runtime/wheatly/audio",
    // Show experimental live transcript while the microphone is still recording.
    "partial_transcript_enabled": true,
    // How often to run preview STT on the current audio snapshot. Raise on weaker hardware.
    "partial_transcript_interval_seconds": 1.1,
    // Minimum captured speech before the first preview STT run.
    "partial_transcript_min_audio_seconds": 0.2,
    // Use the last live preview transcript as the final user text when it is fresh enough.
    "partial_transcript_use_as_final": true,
    // Maximum age of the last preview transcript at recording end before falling back to full STT.
    "partial_transcript_final_max_age_seconds": 6.0
  },
  // Persona identity exposed to prompts.
  "agent": {
    // Assistant display/name in prompts.
    "name": "Wheatly",
    // Compact personality description used by system.md.
    "persona": "compact, fast, slightly nervous, helpful robot",
    // Default answer language.
    "default_response_language": "English"
  },
  // Speech-to-text backend.
  "stt": {
    // Options: keyboard, faster_whisper, whisper_cpp.
    "backend": "faster_whisper",
    // faster-whisper model name.
    "model": "small.en",
    // Force English recognition for now.
    "language": "en",
    // Use CPU for portability.
    "device": "cpu",
    // int8 is the practical CPU baseline.
    "compute_type": "int8",
    // whisper.cpp executable if backend is whisper_cpp.
    "whisper_cpp_binary": "whisper-cli",
    // whisper.cpp model path if backend is whisper_cpp.
    "whisper_cpp_model": "models/whisper/ggml-small.en.bin",
    // Extra whisper.cpp arguments.
    "whisper_cpp_args": [
      "--no-timestamps"
    ]
  },
  // Explicit language mode. Switch by saying configured phrases or via set_language tool.
  "language": {
    // If true, active language controls STT hint/model, LLM prompt hint, and TTS voice.
    "enabled": true,
    // Startup language when no persisted state exists.
    "default": "en",
    // Save last selected language under runtime/wheatly/state.
    "persist": true,
    // File name inside runtime.state_dir.
    "state_file": "language.json",
    // Per-language runtime overrides.
    "languages": {
      // English fast mode.
      "en": {
        // Human-readable language name.
        "label": "English",
        // Language instruction injected into the LLM prompt.
        "response_language": "English",
        // faster-whisper model for this language.
        "stt_model": "small.en",
        // STT language hint.
        "stt_language": "en",
        // TTS backend for English. Keep Piper local/offline here.
        "tts_backend": "piper",
        // macOS say voice label if that backend is used.
        "tts_voice": "Daniel",
        // Piper voice model for this language.
        "tts_piper_model": "models/piper/en_GB-alan-medium.onnx",
        // Optional Piper config path.
        "tts_piper_config": null,
        // Optional Piper speaker id.
        "tts_piper_speaker": null,
        // Edge TTS voice if this language uses backend edge_tts.
        "tts_edge_voice": "en-GB-RyanNeural",
        // Edge TTS rate. Examples: "-5%", "+10%".
        "tts_edge_rate": "+0%",
        // Edge TTS pitch. Examples: "+8Hz", "-4Hz".
        "tts_edge_pitch": "+0Hz",
        // Edge TTS gain. Examples: "+0%", "+10%".
        "tts_edge_volume": "+0%",
        // Piper speed. Lower is faster.
        "tts_length_scale": 0.62,
        // Piper voice variation.
        "tts_noise_scale": 0.72,
        // Piper prosody variation.
        "tts_noise_w_scale": 0.82,
        // Silence inserted after sentences.
        "tts_sentence_silence": 0.0,
        // Playback gain multiplier.
        "tts_volume": 1.05,
        // Silence prepended before playback to avoid clipped first letters.
        "tts_leading_silence_ms": 0,
        // English first streamed TTS chunk target. Higher avoids tiny "Sure." chunks.
        "tts_stream_initial_min_words": 5,
        // English later streamed TTS chunk target. Higher reduces playback gaps between sentences.
        "tts_stream_min_words": 18,
        // English hard cap for streamed TTS chunks.
        "tts_stream_max_words": 70,
        // English minimum timeout fallback chunk size.
        "tts_stream_feedback_min_words": 10,
        // English maximum wait before first speech feedback.
        "tts_stream_max_initial_wait_seconds": 0.35,
        // Spoken/written confirmation after switching.
        "confirmation": "Hi",
        // Printed/spoken when the smarter online model is selected while starting in English.
        "online_model_message": "using smarter online model",
        // Printed/spoken when the local offline model is selected while starting in English.
        "offline_model_message": "using offline model",
        // Exact-ish phrases that trigger direct switching before the LLM.
        "switch_phrases": [
          "switch to english",
          "speak english",
          "talk in english",
          "use english",
          "prepni na anglictinu",
          "hovor po anglicky"
        ],
        // Generic command phrases spoken in English. If already in English, this toggles to the previous/next language.
        "switch_language_phrases": [
          "switch language",
          "change language",
          "switch the language"
        ]
      },
      // Slovak quality mode. Medium Whisper is slower but better for Slovak.
      "sk": {
        // Human-readable language name.
        "label": "Slovak",
        // Language instruction injected into the LLM prompt.
        "response_language": "Slovak",
        // faster-whisper model for this language.
        "stt_model": "medium",
        // STT language hint.
        "stt_language": "sk",
        // Slovak TTS backend. Current default is online Microsoft Edge neural voice for a male voice.
        "tts_backend": "edge_tts",
        // Human-readable/current voice label.
        "tts_voice": "sk-SK-LukasNeural",
        // Piper fallback voice model. To return to the old local female Slovak voice, set tts_backend to "piper".
        "tts_piper_model": "models/piper/sk_SK-lili-medium.onnx",
        // Optional Piper config path.
        "tts_piper_config": null,
        // Optional Piper speaker id.
        "tts_piper_speaker": null,
        // Edge TTS Slovak male voice.
        "tts_edge_voice": "sk-SK-LukasNeural",
        // Edge TTS speaking rate. Slightly slower for clearer Slovak.
        "tts_edge_rate": "-4%",
        // Edge TTS pitch lift to keep it closer to the energetic English character.
        "tts_edge_pitch": "+8Hz",
        // Edge TTS gain.
        "tts_edge_volume": "+0%",
        // Piper speed. Slovak is slower for clearer pronunciation.
        "tts_length_scale": 0.84,
        // Piper voice variation. Slightly lower for a calmer, less sharp Slovak voice.
        "tts_noise_scale": 0.66,
        // Piper prosody variation.
        "tts_noise_w_scale": 0.78,
        // Silence inserted after sentences.
        "tts_sentence_silence": 0.04,
        // Playback gain multiplier.
        "tts_volume": 1.05,
        // Silence prepended before playback to avoid clipped first letters.
        "tts_leading_silence_ms": 80,
        // Slovak first streamed TTS chunk target.
        "tts_stream_initial_min_words": 1,
        // Slovak later streamed TTS chunk target.
        "tts_stream_min_words": 10,
        // Slovak hard cap for streamed TTS chunks.
        "tts_stream_max_words": 60,
        // Slovak minimum timeout fallback chunk size.
        "tts_stream_feedback_min_words": 8,
        // Slovak maximum wait before first speech feedback.
        "tts_stream_max_initial_wait_seconds": 0.5,
        // Spoken/written confirmation after switching.
        "confirmation": "Ahoj",
        // Printed/spoken when the smarter online model is selected while starting in Slovak.
        "online_model_message": "Používam múdrejší online model.",
        // Printed/spoken when the local offline model is selected while starting in Slovak.
        "offline_model_message": "Používam offline model.",
        // Exact-ish phrases that trigger direct switching before the LLM.
        "switch_phrases": [
          "switch to slovak",
          "speak slovak",
          "talk in slovak",
          "use slovak",
          "hovor po slovensky",
          "prepni na slovencinu",
          "prejdi na slovencinu"
        ],
        // Generic command phrases spoken in Slovak. If already in Slovak, this toggles to the previous/next language.
        "switch_language_phrases": [
          "prepni jazyk",
          "zmen jazyk",
          "prehod jazyk"
        ]
      }
    }
  },
  // Local LLM runtime.
  "llm": {
    // Options: echo, ollama, openai_compat, llama_cpp, vllm, sglang.
    "backend": "ollama",
    // Ollama model tag.
    "model": "qwen3.5:4b",
    // Ollama API URL.
    "base_url": "http://localhost:11434",
    // API key for OpenAI-compatible backends; ignored by Ollama.
    "api_key": "EMPTY",
    // Sampling temperature.
    "temperature": 0.55,
    // Nucleus sampling cutoff.
    "top_p": 0.8,
    // Maximum generated tokens. Prompt still asks for short answers by default.
    "max_tokens": 2000,
    // HTTP request timeout.
    "timeout_seconds": 60.0,
    // Number of previous user/assistant turns to keep.
    "context_turns": 6,
    // Disable thinking mode for voice latency.
    "enable_thinking": false,
    // Strip <think>/reasoning output. Keep false when the model is configured not to think.
    "strip_reasoning": false,
    // Optional smarter OpenAI-compatible model checked at each new chat.
    "remote": {
      // If true, try this backend before using the local model.
      "enabled": true,
      // Remote backend type. LM Studio uses OpenAI-compatible API.
      "backend": "openai_compat",
      // LM Studio OpenAI API base URL. /v1 is accepted here.
      "base_url": "http://jankas-mac-mini.local:1234/v1",
      // Model name. Empty string lets LM Studio use its current/default loaded model.
      "model": "",
      // API key for OpenAI-compatible servers. LM Studio usually ignores this.
      "api_key": "EMPTY",
      // Very fast startup probe timeout.
      "probe_timeout_seconds": 0.8,
      // Request timeout after the remote model has been selected.
      "request_timeout_seconds": 120.0,
      // Printed/spoken when the remote model is available.
      "online_message": "using smarter online model",
      // Printed/spoken when the remote model is not reachable.
      "offline_message": "using offline model"
    }
  },
  // Text-to-speech and playback.
  "tts": {
    // Options: auto, none, macos_say, piper, external.
    "backend": "piper",
    // Enable speech output by default for this profile.
    "enabled": true,
    // Human-readable voice label.
    "voice": "Daniel",
    // Generated TTS audio folder.
    "output_dir": "runtime/wheatly/audio",
    // Play audio after synthesis.
    "playback": true,
    // Optional custom playback command. Null uses built-in playback.
    "playback_command": null,
    // Piper executable path.
    "piper_binary": ".venv/bin/piper",
    // Piper voice model path.
    "piper_model": "models/piper/en_GB-alan-medium.onnx",
    // Optional Piper config path. Null lets Piper infer it beside the model.
    "piper_config": null,
    // Optional Piper speaker id for multi-speaker models.
    "piper_speaker": null,
    // Edge TTS voice if backend is edge_tts.
    "edge_voice": "en-GB-RyanNeural",
    // Edge TTS speaking rate. Examples: "-5%", "+10%".
    "edge_rate": "+0%",
    // Edge TTS pitch adjustment. Examples: "+8Hz", "-4Hz".
    "edge_pitch": "+0Hz",
    // Edge TTS volume adjustment. Examples: "+0%", "+10%".
    "edge_volume": "+0%",
    // Lower is faster speech.
    "length_scale": 0.62,
    // Piper voice variation.
    "noise_scale": 0.72,
    // Piper prosody variation.
    "noise_w_scale": 0.82,
    // Silence inserted after sentences.
    "sentence_silence": 0.0,
    // Playback gain multiplier.
    "volume": 1.05,
    // Silence prepended before playback to avoid clipped first letters.
    "leading_silence_ms": 0,
    // Speak chunks before the full answer is complete.
    "stream_speech": true,
    // Adapt first spoken chunk from observed LLM/TTS speeds.
    "adaptive_streaming": true,
    // First spoken chunk target.
    "stream_initial_min_words": 5,
    // Later spoken chunk target.
    "stream_min_words": 18,
    // Hard cap for spoken chunks.
    "stream_max_words": 70,
    // Fallback first chunk size when startup wait expires.
    "stream_feedback_min_words": 10,
    // Maximum initial wait before some speech feedback starts.
    "stream_max_initial_wait_seconds": 0.35,
    // External TTS command for backend external. Use {text} and {output} placeholders.
    "external_command": null,
    // Optional ffmpeg post-filter.
    "filter": {
      // Disabled because filtered chunk playback caused static tails on macOS.
      "enabled": false,
      // ffmpeg executable.
      "ffmpeg_binary": "ffmpeg",
      // Filter preset name in src/wheatly/audio/filter.py.
      "preset": "wheatley_bright"
    }
  },
  // Local tool policy.
  "tools": {
    // Enable tool calling and deterministic pre-routing.
    "enabled": true,
    // Whitelisted shell commands by logical name. Keep empty unless you add safe tools.
    "allowed_commands": {},
    // Optional camera command. Leave null until a camera is configured.
    "photo_command": null
  },
  // Editable profile files. Relative paths resolve inside this profile folder.
  "prompts": {
    // Main system behavior.
    "system_path": "system.md",
    // Always-on user preference instructions.
    "user_path": "user.md",
    // Tool descriptions and tool instructions.
    "tools_path": "tools.jsonc",
    // Persistent memory injected into each new turn.
    "memory_path": "memory.md"
  }
}
